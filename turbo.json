{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"],
      "env": [
        "DISCORD_CLIENT_ID",
        "DISCORD_CLIENT_SECRET",
        "AUTH_SECRET",
        "BOT_API_URL",
        "INTERNAL_API_KEY",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_DISCORD_CLIENT_ID",
        "NEXT_PUBLIC_DISCORD_DEVELOPERS",
        "GOOGLE_SITE_VERIFICATION",
        "NEXT_PUBLIC_SENTRY_DSN"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:run": {
      "dependsOn": ["^test:run"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:prod": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "start:prod": {
      "cache": false,
      "persistent": true
    }
  }
}
