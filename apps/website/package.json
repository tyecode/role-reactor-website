{
  "name": "website",
  "version": "1.1.0",
  "description": "Official website and documentation for Role Reactor Discord bot",
  "type": "module",
  "private": true,
  "keywords": [
    "discord",
    "bot",
    "roles",
    "documentation",
    "next.js"
  ],
  "author": "qodinger",
  "license": "MIT",
  "homepage": "https://rolereactor.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/qodinger/role-reactor-website"
  },
  "scripts": {
    "build": "next build && node scripts/after-build.js",
    "dev": "next dev --turbo --port 8080",
    "start": "PORT=8080 node --env-file=.env.local .next/standalone/apps/website/server.js",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "postinstall": "fumadocs-mdx",
    "analyze": "ANALYZE=true next build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
