# =============================================================================
# Role Reactor Website - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# For local development: cp .env.example .env.local
#
# Legend:
#   [REQUIRED]  - App will not start without this
#   [OPTIONAL]  - Has a default value or feature is optional

# =============================================================================
# 1. DISCORD OAUTH CONFIGURATION
# =============================================================================

# Discord OAuth Client ID [REQUIRED]
# Get from: https://discord.com/developers/applications → OAuth2
DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord OAuth Client Secret [REQUIRED]
# Get from: https://discord.com/developers/applications → OAuth2 → Reset Secret
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Discord Client ID (public, for client-side usage) [OPTIONAL]
# Should match DISCORD_CLIENT_ID - exposed to the browser for OAuth flows
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id_here

# =============================================================================
# 2. AUTHENTICATION
# =============================================================================

# NextAuth.js Secret [REQUIRED]
# Used for session encryption. Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# =============================================================================
# 3. APPLICATION URLS
# =============================================================================

# Base URL of the website [OPTIONAL]
# Used for metadata and sitemap generation
# Local: http://localhost:8080 | Production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:8080

# =============================================================================
# 4. BOT API CONFIGURATION
# =============================================================================

# Role Reactor Bot API URL [REQUIRED]
# Used for fetching pricing, creating payments, and supporter data
# Local: http://localhost:3030 | Production: https://api.rolereactor.app
BOT_API_URL=http://localhost:3030

# Internal API Key [REQUIRED]
# Shared secret between website and bot for authorized internal requests
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=your_internal_api_key_here

# =============================================================================
# 5. DEVELOPER / ADMIN
# =============================================================================

# Developer Discord User IDs [OPTIONAL]
# Comma-separated list of Discord user IDs with admin access
NEXT_PUBLIC_DISCORD_DEVELOPERS=

# =============================================================================
# 6. ANALYTICS & MONITORING
# =============================================================================

# PropellerAds Zone ID (In-Page Push) [OPTIONAL]
# Get from: https://publishers.propellerads.com → Zones
NEXT_PUBLIC_PROPELLERADS_ZONE_ID=10853041

# PropellerAds Zone IDs per section [OPTIONAL]
NEXT_PUBLIC_PROPELLERADS_HOME_ZONE=
NEXT_PUBLIC_PROPELLERADS_LEADERBOARDS_TOP_ZONE=
NEXT_PUBLIC_PROPELLERADS_LEADERBOARDS_BOTTOM_ZONE=
NEXT_PUBLIC_PROPELLERADS_LEADERBOARD_TOP_ZONE=
NEXT_PUBLIC_PROPELLERADS_LEADERBOARD_BOTTOM_ZONE=
NEXT_PUBLIC_PROPELLERADS_FEED_ZONE=
NEXT_PUBLIC_PROPELLERADS_DOCS_ZONE=

# Google Site Verification [OPTIONAL]
# Used for Google Search Console verification meta tag
GOOGLE_SITE_VERIFICATION=

# Sentry DSN [OPTIONAL]
# Used for error tracking and performance monitoring
NEXT_PUBLIC_SENTRY_DSN=

# Custom Analytics Endpoint [OPTIONAL]
# Endpoint for sending web vitals / custom analytics data
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# =============================================================================
# DISCORD OAUTH REDIRECT URI SETUP
# =============================================================================
#
# IMPORTANT: You must add the following redirect URI in your Discord application:
#
# 1. Go to https://discord.com/developers/applications
# 2. Select your application → OAuth2
# 3. Add Redirect URI:
#    - Local:      http://localhost:8080/api/auth/callback/discord
#    - Production: https://your-domain.com/api/auth/callback/discord
#
# =============================================================================
