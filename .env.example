# =============================================================================
# Role Reactor Website Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# For local development: cp .env.example .env.local

# =============================================================================
# DISCORD OAUTH CONFIGURATION (REQUIRED)
# =============================================================================

# Discord OAuth Client ID [REQUIRED]
# Get this from https://discord.com/developers/applications
# 1. Go to your Discord application
# 2. Navigate to OAuth2 section
# 3. Copy the Client ID
DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord OAuth Client Secret [REQUIRED]
# Get this from https://discord.com/developers/applications
# 1. Go to your Discord application
# 2. Navigate to OAuth2 section
# 3. Click "Reset Secret" if needed
# 4. Copy the Client Secret
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# =============================================================================
# AUTHENTICATION CONFIGURATION (REQUIRED)
# =============================================================================

# NextAuth.js Secret [REQUIRED]
# Generate a random secret for session encryption
# You can generate one using: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
AUTH_SECRET=your_auth_secret_here

# Base URL [OPTIONAL]
# The base URL of your website (used for OAuth redirects)
# For local development: http://localhost:8080
# For production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:8080

# =============================================================================
# BOT API CONFIGURATION (REQUIRED FOR PAYMENTS)
# =============================================================================

# Role Reactor Bot API URL [REQUIRED]
# Used for fetching pricing, creating payments via Plisio, and supporter data
# Default production URL: https://api.rolereactor.app
# For local development: Use http://localhost:3030 in your .env.local
BOT_API_URL=http://localhost:3030

# =============================================================================
# DISCORD OAUTH REDIRECT URI SETUP
# =============================================================================
# 
# IMPORTANT: You must add the following redirect URI in your Discord application:
# 
# 1. Go to https://discord.com/developers/applications
# 2. Select your application
# 3. Go to OAuth2 section
# 4. Add Redirect URI:
#    - For local: http://localhost:8080/api/auth/callback/discord
#    - For production: https://your-domain.com/api/auth/callback/discord
# 
# =============================================================================
