{
  "name": "role-reactor-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:prod": "turbo dev:prod",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "start": "turbo start",
    "start:prod": "turbo start:prod",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
