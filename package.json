    "turbo": "^2.8.9"
  },
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "@radix-ui/react-switch": "^1.2.6",
    "husky": "^9.1.7",
    "import-in-the-middle": "^3.0.0"
